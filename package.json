{
  "name": "base",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sort:css": "prettier --write \"./src/**/*.css\"",
    "convert_images": "node convert.js --formats avif,webp,jpg,png8 --sizes 1600w,1200w,1000w,640w,320w --aspect 16/9 --bg \"#ffffff\"",
    "convert_images:clean": "npm run convert_images -- --clean",
    "clean_images": "node convert.js --clean"
  },
  "browserslist": [
    "last 4 versions",
    "> 2% in RU",
    "Safari >= 13"
  ],
  "devDependencies": {
    "browserslist": "^4.24.0",
    "commander": "^12.1.0",
    "glob": "^10.4.1",
    "lightningcss": "^1.30.1",
    "postcss": "^8.5.15",
    "postcss-mixins": "^12.1.2",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.2.5",
    "prettier-plugin-css-order": "^2.1.2",
    "sharp": "^0.33.5",
    "vite": "^8.0.16",
    "vite-plugin-ejs": "^1.7.0"
  }
}